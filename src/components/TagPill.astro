---
interface Props {
  tag: string;
  count?: number;
  active?: boolean;
}
const { tag, count, active = false } = Astro.props;
---

<a
  href={`/blog/tags/${tag}`}
  class:list={[
    'inline-flex items-center gap-1 rounded-[var(--radius-base)] border px-2 py-0.5 font-mono text-xs transition-colors',
    active
      ? 'border-accent bg-accent-soft text-accent'
      : 'border-border text-muted hover:border-accent hover:text-accent',
  ]}
>
  <span class="opacity-60">#</span>{tag}{count !== undefined && <span class="opacity-50">({count})</span>}
</a>
