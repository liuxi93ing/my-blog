---
import { NAV_LINKS, SITE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/80 backdrop-blur">
  <nav class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="font-mono text-sm font-semibold tracking-tight">
      <span class="text-accent">~/</span><span>{SITE.title}</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="flex items-center gap-1 font-mono text-sm">
        {
          NAV_LINKS.slice(1).map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'rounded-[var(--radius-base)] px-2.5 py-1.5 transition-colors hover:text-accent',
                  isActive(link.href) ? 'text-accent' : 'text-muted',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <a
        href="/search"
        aria-label="Search"
        title="Search"
        class="grid h-9 w-9 place-items-center rounded-[var(--radius-base)] border border-border text-muted transition-colors hover:border-accent hover:text-accent"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>

      <ThemeToggle />
    </div>
  </nav>
</header>
