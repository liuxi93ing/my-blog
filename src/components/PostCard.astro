---
import type { CollectionEntry } from 'astro:content';
import { formatDate, toSlug } from '../lib/content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, date, tags } = post.data;
const href = `/blog/${toSlug(post.id)}`;
---

<article class="group border-b border-border py-6">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
    <h2 class="font-mono text-lg font-semibold leading-snug">
      <a href={href} class="transition-colors group-hover:text-accent">
        {title}
      </a>
    </h2>
    <time datetime={date.toISOString()} class="shrink-0 font-mono text-xs text-muted">
      {formatDate(date)}
    </time>
  </div>
  <p class="mt-2 text-sm text-muted">{description}</p>
  {
    tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="font-mono text-xs text-muted">
            <span class="text-accent">#</span>
            {tag}
          </span>
        ))}
      </div>
    )
  }
</article>
