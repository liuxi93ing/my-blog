---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE, SOCIAL } from '../consts';
import { getPosts, getProjects } from '../lib/content';

const posts = (await getPosts()).slice(0, 5);
const allProjects = await getProjects();
const featured = allProjects.filter((p) => p.data.featured).slice(0, 4);
const homeProjects = featured.length ? featured : allProjects.slice(0, 4);
---

<BaseLayout>
  <!-- Hero / terminal intro -->
  <section class="mx-auto max-w-3xl py-8">
    <p class="font-mono text-sm text-muted">
      <span class="text-accent">$</span> whoami
    </p>
    <h1 class="mt-3 font-mono text-3xl font-bold leading-tight sm:text-4xl">
      {SITE.title}<span class="animate-pulse text-accent">_</span>
    </h1>
    <p class="mt-4 max-w-xl text-muted">
      {SITE.description}
    </p>
    <div class="mt-6 flex gap-4 font-mono text-sm">
      <a href="/blog" class="text-accent hover:underline">read the blog →</a>
      <a href={SOCIAL.github} target="_blank" rel="noopener" class="text-muted hover:text-accent">github</a>
    </div>
  </section>

  <!-- Latest posts -->
  <section class="mt-12">
    <div class="flex items-baseline justify-between border-b border-border pb-2">
      <h2 class="font-mono text-sm font-semibold uppercase tracking-wider text-muted">
        latest posts
      </h2>
      <a href="/blog" class="font-mono text-xs text-accent hover:underline">all →</a>
    </div>
    {
      posts.length ? (
        <div>
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="py-6 font-mono text-sm text-muted">No posts yet.</p>
      )
    }
  </section>

  <!-- Featured projects -->
  <section class="mt-14">
    <div class="flex items-baseline justify-between border-b border-border pb-2">
      <h2 class="font-mono text-sm font-semibold uppercase tracking-wider text-muted">
        featured projects
      </h2>
      <a href="/projects" class="font-mono text-xs text-accent hover:underline">all →</a>
    </div>
    {
      homeProjects.length ? (
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {homeProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      ) : (
        <p class="py-6 font-mono text-sm text-muted">No projects yet.</p>
      )
    }
  </section>
</BaseLayout>
