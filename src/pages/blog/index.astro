---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import TagPill from '../../components/TagPill.astro';
import { getPosts, getTags } from '../../lib/content';

const posts = await getPosts();
const tags = await getTags();
---

<BaseLayout title="Blog" description="Articles, notes, and write-ups.">
  <div class="mx-auto max-w-3xl">
    <header class="border-b border-border pb-4">
      <h1 class="font-mono text-2xl font-semibold">
        <span class="text-accent">~/</span>blog
      </h1>
      <p class="mt-2 text-sm text-muted">{posts.length} post{posts.length === 1 ? '' : 's'}</p>
    </header>

    {
      tags.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-1.5">
          {tags.map(({ tag, count }) => (
            <TagPill tag={tag} count={count} />
          ))}
        </div>
      )
    }

    <div class="mt-4">
      {
        posts.length ? (
          posts.map((post) => <PostCard post={post} />)
        ) : (
          <p class="py-8 font-mono text-sm text-muted">No posts yet — check back soon.</p>
        )
      }
    </div>
  </div>
</BaseLayout>
