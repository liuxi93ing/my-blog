---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found.">
  <div class="mx-auto max-w-xl py-16 text-center">
    <pre class="inline-block text-left font-mono text-sm text-accent">$ cd {Astro.url.pathname}
bash: cd: no such file or directory</pre>
    <h1 class="mt-8 font-mono text-5xl font-bold">404</h1>
    <p class="mt-3 text-muted">This path doesn't resolve.</p>
    <div class="mt-6 flex justify-center gap-4 font-mono text-sm">
      <a href="/" class="text-accent hover:underline">~/ home</a>
      <a href="/blog" class="text-muted hover:text-accent">blog</a>
      <a href="/projects" class="text-muted hover:text-accent">projects</a>
    </div>
  </div>
</BaseLayout>
