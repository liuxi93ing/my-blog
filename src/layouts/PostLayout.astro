---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import TagPill from '../components/TagPill.astro';
import { formatDate, readingTime } from '../lib/content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, date, updated, tags } = post.data;
const minutes = readingTime(post.body);
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-[720px]">
    <a href="/blog" class="font-mono text-xs text-muted transition-colors hover:text-accent">
      <span class="text-accent">←</span> back to blog
    </a>

    <header class="mt-6 border-b border-border pb-6">
      <h1 class="font-mono text-3xl font-semibold leading-tight">{title}</h1>
      <p class="mt-3 text-muted">{description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-xs text-muted">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        <span>·</span>
        <span>{minutes} min read</span>
        {updated && (
          <>
            <span>·</span>
            <span>updated {formatDate(updated)}</span>
          </>
        )}
      </div>
      {
        tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <TagPill tag={tag} />
            ))}
          </div>
        )
      }
    </header>

    <div class="prose mt-8" data-pagefind-body>
      <slot />
    </div>
  </article>
</BaseLayout>
